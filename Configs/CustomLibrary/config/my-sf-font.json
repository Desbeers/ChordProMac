pdf {
    // The font families.
    fontconfig {
      sans {
        ""         : /Library/Fonts/SF-Pro-Text-Regular.otf
        bold       : /Library/Fonts/SF-Pro-Text-Regular.otf
        bolditalic : /Library/Fonts/SF-Pro-Text-BoldItalic.otf
