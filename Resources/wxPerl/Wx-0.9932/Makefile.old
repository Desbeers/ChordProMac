# DLBASE  = Basename part of dynamic library. May be just equal BASEEXT.
MAKE = make
FULLEXT = Wx
BASEEXT = Wx
PARENT_NAME = 
DLBASE = $(BASEEXT)
VERSION_FROM = Wx.pm
INC = -I. -I. -I/usr/local/lib/wx/include/osx_cocoa-unicode-3.2 -I/usr/local/include/wx-3.2 
DEFINE = -D_FILE_OFFSET_BITS=64 -DWXUSINGDLL -D__WXMAC__ -D__WXOSX__ -D__WXOSX_COCOA__  
OBJECT = Wx$(OBJ_EXT) Constant$(OBJ_EXT) Controls$(OBJ_EXT) Event$(OBJ_EXT) Frames$(OBJ_EXT) GDI$(OBJ_EXT) Window$(OBJ_EXT) 
LDFROM = $(OBJECT)
LINKTYPE = dynamic
BOOTDEP = 

