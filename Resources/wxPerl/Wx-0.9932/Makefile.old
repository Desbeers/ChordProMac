cpp/v_cback_def.h : script/make_v_cback.pl
	$(PERL) script/make_v_cback.pl > cpp/v_cback_def.h

wxt_overload :
	$(PERL) script/wxperl_overload cpp/ovl_const.cpp cpp/ovl_const.h overload.lst
	$(TOUCH) wxt_overload

